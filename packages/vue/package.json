{
  "name": "quick-bug-reporter-vue",
  "version": "1.0.0",
  "description": "Drop-in bug reporter for Vue 3 apps — screenshot, video capture, annotation, and Linear/Jira/Cloud integration.",
  "author": "Ali Abdulkadir Ali",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "vue",
    "vue3",
    "bug-reporter",
    "screenshot",
    "screen-recording",
    "linear",
    "jira",
    "cloud"
  ],
  "dependencies": {
    "@quick-bug-reporter/core": "workspace:*",
    "html2canvas-pro": "^1.6.6"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5",
    "vue": "^3.5.0"
  }
}
