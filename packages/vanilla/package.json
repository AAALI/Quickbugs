{
  "name": "quick-bug-reporter",
  "version": "1.0.0",
  "description": "Zero-dependency bug reporter for any web app — screenshot, video capture, and Linear/Jira/Cloud integration via script tag or npm.",
  "author": "Ali Abdulkadir Ali",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./cdn": "./dist/quickbugs.iife.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "bug-reporter",
    "screenshot",
    "screen-recording",
    "vanilla",
    "script-tag",
    "linear",
    "jira",
    "cloud"
  ],
  "dependencies": {
    "@quick-bug-reporter/core": "workspace:*",
    "html2canvas-pro": "^1.6.6"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5"
  }
}
